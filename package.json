{
  "name": "shopnext-fullstack",
  "version": "1.0.0",
  "description": "Full Stack MERN E-Commerce Website",
  "private": true,
  "scripts": {
    "install": "cd backend && npm install && cd ../frontend/shopnext-frontend && npm install",
    "dev:server": "cd backend && npm run dev",
    "dev:client": "cd frontend/shopnext-frontend && npm run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",

    "build": "cd frontend/shopnext-frontend && npm install && npm run build",

    "start": "cd backend && npm start"
  },
  "dependencies": {
    "concurrently": "^9.2.1"
  }
}